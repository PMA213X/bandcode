# BandCode .gitignore

# === 敏感配置 ===
settings.json
.env
.env.*
*.key
*.pem

# === 运行时数据 ===
.mimo/sessions/
.mimo/checkpoints/
.mimo/notes/
.mimo/tasks/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
*.egg-info/
dist/
build/

# === Node.js ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === 系统文件 ===
.DS_Store
Thumbs.db

# === ChromaDB ===
chroma/
chroma_db/

# === 日志 ===
*.log
logs/

# === 测试 ===
.coverage
htmlcov/
.pytest_cache/
test_connection.py

# === MiMoCode ===
.mimocode/
